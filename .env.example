# PocketBase
POCKETBASE_URL=http://localhost:8090
PUBLIC_POCKETBASE_URL=http://localhost:8090
# Wheel collection name (default: thewheel)
POCKETBASE_WHEEL_COLLECTION=thewheel

# PocketBase superuser credentials (used for server-side admin API access)
POCKETBASE_SUPERUSER_EMAIL=admin@example.com
POCKETBASE_SUPERUSER_PASSWORD=

ORIGIN=

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord Bot (https://discord.com/developers/applications -> Bot tab)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Comma-separated Discord user IDs that always have admin access
ADMIN_DISCORD_USER_IDS=
